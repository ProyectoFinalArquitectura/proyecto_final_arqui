{
  "info": {
    "name": "Proyecto Final Arqui - API",
    "description": "Colección completa de endpoints del backend con casos positivos y negativos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "organizerName", "value": "Organizador Demo" },
    { "key": "organizerEmail", "value": "" },
    { "key": "organizerPassword", "value": "organizador123" },
    { "key": "organizerToken", "value": "" },
    { "key": "adminEmail", "value": "admin@local.com" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "adminToken", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "attendeeId", "value": "" },
    { "key": "registrationId", "value": "" },
    { "key": "attendeeName", "value": "Asistente Demo" },
    { "key": "attendeeEmail", "value": "" },
    { "key": "attendeePhone", "value": "3000000000" }
