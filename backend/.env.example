# Opcional: si no defines nada, el backend genera SECRET_KEY y JWT_SECRET_KEY
# al arrancar con secrets (cómodo en desarrollo).
#
# En producción define siempre ambas variables para que no cambien entre reinicios
# (sesiones y JWT siguen siendo válidos).
#
# Ejemplo para generar valores estables y pegarlos aquí o en el servidor:
#   python -c "import secrets; print('SECRET_KEY=' + secrets.token_hex(32)); print('JWT_SECRET_KEY=' + secrets.token_hex(32))"
#
# SECRET_KEY=
# JWT_SECRET_KEY=
