        {
          "name": "Get Event Attendees",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/attendees/event/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "attendees", "event", "{{eventId}}"] }
          }
        },
        {
          "name": "Cancel Registration",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] } }],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{organizerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/attendees/registration/{{registrationId}}/cancel", "host": ["{{baseUrl}}"], "path": ["api", "attendees", "registration", "{{registrationId}}", "cancel"] }
          }
