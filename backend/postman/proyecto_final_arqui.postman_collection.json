            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{attendeeName}}\",\n  \"email\": \"{{attendeeEmail}}\",\n  \"phone\": \"{{attendeePhone}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/attendees/event/{{eventId}}/register", "host": ["{{baseUrl}}"], "path": ["api", "attendees", "event", "{{eventId}}", "register"] }
